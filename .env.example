# Database
DB_USER=musicplayer
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=musicplayer
DB_HOST=postgres
DB_PORT=5432

# Security
SECRET_KEY=change-me-to-a-random-64-char-string
CORS_ORIGINS=http://localhost:3000

# Music Sources (comma-separated, use lowercase keys)
# Core reliable sources: migu, kuwo, joox
# Extended sources: netease, qq, kugou, qianqian, bilibili
# International: spotify, deezer, tidal, soundcloud, youtube
MUSIC_SOURCES=migu,kuwo,joox,netease

# Performance
SOURCE_TIMEOUT=8
SEARCH_PARALLELISM=10
UVICORN_WORKERS=2
CELERY_WORKERS=1
CELERY_CONCURRENCY=2

# Paths
DOWNLOAD_DIR=/downloads
CACHE_DIR=/tmp/musicplayer_cache

# Ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
